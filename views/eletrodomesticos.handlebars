<header>

<h1>Aqua<span>Power</span></h1>

<nav class="abas">

<a href="/eletrodomesticos" class="ativa">
Equipamentos
</a>

<a href="/equipamentos-ocultos">
Equipamentos Ocultos
</a>

</nav>

</header>

<main>

<section class="titulo">

<h2>Equipamentos</h2>

<p>
Consulte, cadastre, edite e oculte equipamentos.
</p>

</section>

<section class="cadastro">

<h3>{{#if equipamentoEditar}}Editar Equipamento{{else}}Novo Equipamento{{/if}}</h3>

<form action="{{#if equipamentoEditar}}/eletrodomesticos/editar/{{equipamentoEditar.id}}{{else}}/eletrodomesticos{{/if}}" method="POST">

<input
type="text"
name="nome"
placeholder="Nome do equipamento"
value="{{equipamentoEditar.nome}}"
required
>

<select name="categoria" required>

<option value="">Selecione uma categoria</option>

<option value="Cozinha">Cozinha</option>
<option value="Lavanderia">Lavanderia</option>
<option value="Climatização">Climatização</option>
<option value="Entretenimento">Entretenimento</option>
<option value="Informática">Informática</option>
<option value="Limpeza">Limpeza</option>
<option value="Água">Água</option>
<option value="Banheiro">Banheiro</option>
<option value="Cuidados pessoais">Cuidados pessoais</option>

</select>

<input
type="number"
step="0.01"
name="consumoEnergia"
placeholder="Energia (kWh/mês)"
value="{{equipamentoEditar.consumoEnergia}}"
required
>

<input
type="number"
step="0.01"
name="consumoAgua"
placeholder="Água (L/mês)"
value="{{equipamentoEditar.consumoAgua}}"
required
>

<div class="acoes-form">

<button type="submit">

{{#if equipamentoEditar}}
Salvar Alterações
{{else}}
Cadastrar
{{/if}}

</button>

{{#if equipamentoEditar}}

<a href="/eletrodomesticos" class="cancelar">
Cancelar
</a>

{{/if}}

</div>

</form>

</section>

<div class="tabela-container">

<table>

<thead>

<tr>

<th>Equipamento</th>
<th>Categoria</th>
<th>Energia</th>
<th>Água</th>
<th>Ações</th>

</tr>

</thead>

<tbody>

{{#each equipamentos}}

<tr>

<td>{{nome}}</td>
<td>{{categoria}}</td>
<td>{{consumoEnergia}} kWh/mês</td>
<td>{{consumoAgua}} L/mês</td>

<td>

<div class="acoes">

<a
href="/eletrodomesticos/editar/{{id}}"
class="editar"
>
Editar
</a>

<form
action="/ocultar/{{id}}"
method="POST"
>

<button
type="submit"
class="ocultar"
>

Ocultar

</button>

</form>

</div>

</td>

</tr>

{{/each}}

</tbody>

</table>

</div>

</main>